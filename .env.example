# Copy to .env and fill in. Never commit .env.
# This file documents every secret the first vertical slice needs.
# Do NOT put inline comments after a value: the parser keeps them as part of the value.

# --- App ---
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# --- Postgres ---
# pgvector is expected on this instance (CREATE EXTENSION vector).
DATABASE_URL=postgresql+psycopg://albert:albert@localhost:5432/albert

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / token encryption ---
# Used to sign Albert's own session JWTs.
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES: 43200 = 30 days
JWT_EXPIRE_MINUTES=43200
# Fernet key for encrypting third-party OAuth tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-32-byte-urlsafe-base64

# --- Google OAuth (Gmail + Calendar) ---
# Calendar scope is included now so the slice does not need re-consent later.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- LLM provider (provider-agnostic; Anthropic implemented first) ---
# LLM_PROVIDER: anthropic (openai, mistral later)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Model routing per the PRD: cheap model classifies, strong model extracts/drafts.
LLM_CLASSIFY_MODEL=claude-haiku-4-5
LLM_EXTRACT_MODEL=claude-sonnet-4-6
LLM_DRAFT_MODEL=claude-sonnet-4-6

# --- Transcription (voice capture) ---
# TRANSCRIPTION_PROVIDER: none (disables voice; endpoint returns 501) | openai
# Anthropic does not take raw audio, so voice capture needs a separate provider.
TRANSCRIPTION_PROVIDER=none
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=whisper-1

# --- Stripe (payments, level 4) ---
# Test key only. The provider refuses sk_live_ unless ALLOW_LIVE_PAYMENTS=true, which
# you must not set without the steps in docs/integrations/stripe.md.
STRIPE_SECRET_KEY=
ALLOW_LIVE_PAYMENTS=false
