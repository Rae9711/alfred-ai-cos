{
  "name": "albert-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/patch-expo-updates-spawn.mjs",
    "start": "node scripts/patch-expo-updates-spawn.mjs && node ../node_modules/expo/bin/cli start --port 8081",
    "start:phone": "bash scripts/start-phone.sh",
    "login": "node ../node_modules/eas-cli/bin/run login",
    "device:ios": "bash scripts/standalone-ios.sh device",
    "build:ios": "bash scripts/standalone-ios.sh build",
    "install:ios": "bash scripts/standalone-ios.sh install",
    "update:preview": "bash scripts/standalone-ios.sh update",
    "start:web": "bash scripts/start-web.sh",
    "proxy": "node scripts/dev-api-proxy.mjs",
    "refresh": "bash scripts/refresh.sh",
    "stop": "lsof -tiTCP:8081,8082,8083,8000 | xargs kill -9 2>/dev/null; pkill -f 'expo/bin/cli' 2>/dev/null; pkill -f 'cloudflared tunnel' 2>/dev/null; echo 'Stopped Expo/Metro/tunnel'",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@albert/shared-types": "workspace:*",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "expo": "~54.0.35",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.10",
    "eas-cli": "^19.1.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
