{
  "name": "albert-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "start:web": "bash scripts/start-web.sh",
    "proxy": "node scripts/dev-api-proxy.mjs",
    "login": "node ../node_modules/eas-cli/bin/run login",
    "device:ios": "bash scripts/standalone-ios.sh device",
    "build:ios": "bash scripts/standalone-ios.sh build",
    "install:ios": "bash scripts/standalone-ios.sh install",
    "update:preview": "bash scripts/standalone-ios.sh update",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run && node --test scripts/dev-api-proxy.test.mjs"
  },
  "dependencies": {
    "@albert/shared-types": "workspace:*",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "expo": "~54.0.34",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.1.10",
    "eas-cli": "^19.1.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
