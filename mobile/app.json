{
  "expo": {
    "name": "Albert",
    "slug": "albert",
    "scheme": "albert",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.albert.app"
    },
    "android": {
      "package": "com.albert.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-audio",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.0.31:8000"
    }
  }
}
