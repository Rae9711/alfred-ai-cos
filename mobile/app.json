{
  "expo": {
    "name": "Albert",
    "slug": "albert",
    "scheme": "albert",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/45e050ed-fd8c-494a-8173-821548b192f5",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alfredassistants.albert",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["shortcuts"],
        "NSContactsUsageDescription": "Albert looks up contacts when you ask to text someone by name."
      }
    },
    "android": {
      "package": "com.alfredassistants.albert",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      "expo-updates",
      [
        "expo-contacts",
        {
          "contactsPermission": "Albert looks up contacts when you ask to text someone by name."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://alfredaitech.com",
      "router": {},
      "eas": {
        "projectId": "45e050ed-fd8c-494a-8173-821548b192f5"
      }
    },
    "owner": "slurpdurp"
  }
}
