# Albert — production environment template (Hetzner deploy).
# Copy to /opt/albert/repo/.env on the server and fill REAL values. NEVER commit the
# filled file. Every var Albert's config.py reads is here, plus the compose Postgres vars.
#
# Legend:
#   [REQUIRED]   app refuses to boot without it
#   [REGENERATE] do NOT reuse a dev value — mint a fresh secret for prod (commands below)
#   [SET]        must change from the default for prod to work
#   [optional]   safe to leave as-is for the friends-testing round

# ─── App ────────────────────────────────────────────────────────────────────
# [SET] production keeps dev-only endpoints (dev-session, dev seed) DISABLED. Critical
# now that the API is public — a leftover "development" would expose the dev login.
ENVIRONMENT=production
# [SET] public HTTPS base. Used to build the OAuth callback + any absolute links.
APP_BASE_URL=https://albert.alfredassistants.com
LOG_LEVEL=INFO

# ─── Postgres / Redis ─────────────────────────────────────────────────────────
# [REQUIRED] point at the in-compose services by container name (albert_postgres / albert_redis).
# psycopg v3 driver → the +psycopg suffix.
DATABASE_URL=postgresql+psycopg://albert:CHANGE_ME_DB_PASSWORD@albert_postgres:5432/albert
REDIS_URL=redis://albert_redis:6379/0

# [REQUIRED by compose] these create the Postgres role/db; must match DATABASE_URL above.
POSTGRES_USER=albert
# [REGENERATE] strong DB password (also paste into DATABASE_URL):  openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=albert

# ─── Auth / encryption ──────────────────────────────────────────────────────
# [REQUIRED][REGENERATE] >=32 bytes (the dev one was 29 → triggered the insecure-key
# warning). Fresh secret = existing sessions invalidated (fine, no real users yet).
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_REGENERATE_>=32_BYTES
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200
# [REQUIRED][REGENERATE] Fernet key encrypting stored Google tokens. MUST be a valid
# Fernet key, and MUST be stable — rotating it makes already-stored tokens undecryptable.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# [SET] from Google Cloud Console → Credentials (reuse your existing Albert OAuth client).
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
# [SET] must EXACTLY match an Authorized redirect URI registered in that OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=https://albert.alfredassistants.com/api/v1/auth/google/callback

# ─── LLM (Anthropic) ──────────────────────────────────────────────────────────
# [SET] needed for briefings/classification/extraction/drafts.
ANTHROPIC_API_KEY=CHANGE_ME
LLM_PROVIDER=anthropic
LLM_CLASSIFY_MODEL=claude-haiku-4-5
LLM_EXTRACT_MODEL=claude-sonnet-4-6
LLM_DRAFT_MODEL=claude-sonnet-4-6

# ─── Voice transcription ──────────────────────────────────────────────────────
# [optional] "none" disables voice capture (endpoint returns 501). Set "openai" + key to enable.
TRANSCRIPTION_PROVIDER=none
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=whisper-1

# ─── Stripe (payments) ────────────────────────────────────────────────────────
# [optional] leave blank for the testing round. Live payments stay OFF unless both are set.
STRIPE_SECRET_KEY=
ALLOW_LIVE_PAYMENTS=false

# ─── WhatsApp Business Cloud API ──────────────────────────────────────────────
# [optional] leave blank for the testing round.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# GOOGLE_SCOPES is a sensible default in config.py; override only to change requested scopes.
